# ============================================
# AI 简历智能生成平台 - 前端环境变量配置示例
# ============================================

# ========== API 配置 ==========
# 后端 API 地址
VITE_API_BASE_URL=http://127.0.0.1:8000/api/v1

# ========== 应用配置 ==========
# 应用标题
VITE_APP_TITLE=AI 简历

# 是否启用调试模式
VITE_DEBUG=true

# ========== 第三方登录 (可选) ==========
# 微信 AppID (用于微信登录)
# VITE_WECHAT_APP_ID=your-wechat-app-id

# ========== 分析统计 (可选) ==========
# 百度统计 ID
# VITE_BAIDU_ANALYTICS_ID=your-baidu-id

# Google Analytics ID
# VITE_GA_ID=your-ga-id
