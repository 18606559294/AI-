# AI简历智能生成平台 - 环境配置

# 应用配置
APP_NAME=AI简历智能生成平台
DEBUG=true

# 数据库配置
DATABASE_URL=mysql+aiomysql://root:password@localhost:3306/ai_resume

# Redis配置
REDIS_URL=redis://localhost:6379/0

# JWT配置
SECRET_KEY=your-super-secret-key-change-in-production-abc123xyz789
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# OpenAI配置 (请替换为你的API Key)
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=4000
OPENAI_TEMPERATURE=0.7

# 文件存储
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760
