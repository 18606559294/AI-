# ============================================
# AI Resume Platform - 环境变量配置模板
# ============================================
# 使用说明:
# 1. 复制此文件到 .env: cp .env.example .env
# 2. 修改下面的值为你实际的配置
# 3. 切勿将 .env 文件提交到版本控制系统！
# ============================================

# ==================== 应用配置 ====================
APP_NAME=AI简历智能生成平台
DEBUG=false
HOST=0.0.0.0
PORT=8000

# ==================== 数据库配置 ====================
# true = 使用 SQLite (开发环境)
# false = 使用 MySQL (生产环境)
USE_SQLITE=false

# MySQL 连接字符串 (当 USE_SQLITE=false 时使用)
# 格式: mysql+aiomysql://用户名:密码@主机:端口/数据库
DATABASE_URL=mysql+aiomysql://airesume:your_password_here@localhost:3306/ai_resume

# SQLite 连接字符串 (当 USE_SQLITE=true 时使用)
# DATABASE_URL=sqlite+aiosqlite:///./data/ai_resume.db

# 数据库连接池配置
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# ==================== Redis 配置 ====================
# 用于速率限制和缓存
# 留空使用内存存储（开发/测试环境）
REDIS_URL=redis://localhost:6379/0

# ==================== JWT 安全配置 ====================
# ⚠️ 生产环境必须使用至少 32 位的强随机密钥
# 生成命令: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_KEY_AT_LEAST_32_CHARACTERS_LONG

# JWT 令牌过期时间
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==================== AI 模型配置 ====================
# 默认 AI 提供商: openai / deepseek / xiaomi
DEFAULT_AI_PROVIDER=xiaomi

# --- OpenAI GPT 配置 ---
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=4000
OPENAI_TEMPERATURE=0.7

# --- DeepSeek 配置 (中国 AI) ---
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MAX_TOKENS=4000
DEEPSEEK_TEMPERATURE=0.7

# --- 小米 MiMo AI 配置 ---
# 官方文档: https://platform.xiaomimimo.com/
XIAOMI_API_KEY=sk-your-xiaomi-api-key-here
XIAOMI_MODEL=mimo-v2-pro
XIAOMI_BASE_URL=https://api.xiaomimimo.com/v1
XIAOMI_MAX_TOKENS=4000
XIAOMI_TEMPERATURE=0.7

# ==================== OAuth 配置 ====================
# Google OAuth 配置
# 获取凭证: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# GitHub OAuth 配置
# 创建 OAuth App: https://github.com/settings/developers
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:8000/api/v1/auth/github/callback

# OAuth 状态存储 TTL (秒)
OAUTH_STATE_TTL_SECONDS=600

# ==================== 邮件配置 (可选) ====================
# 用于发送验证邮件和密码重置
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@yourdomain.com

# ==================== 微信登录配置 (可选) ====================
WECHAT_APP_ID=your-wechat-app-id
WECHAT_APP_SECRET=your-wechat-app-secret

# ==================== 文件上传配置 ====================
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760

# ==================== CORS 配置 ====================
# 允许的前端域名（生产环境只允许实际域名）
CORS_ORIGINS=http://localhost:3000,http://localhost,https://yourdomain.com

# ==================== API 配置 ====================
API_V1_PREFIX=/api/v1
