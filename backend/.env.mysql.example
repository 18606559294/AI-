# MySQL 生产环境配置模板
# 复制此文件到 .env 并修改相应的值

# ========== 数据库配置 ==========
# 使用 MySQL（设为 false 启用 MySQL）
USE_SQLITE=false

# MySQL 连接字符串
# 格式: mysql+aiomysql://用户名:密码@主机:端口/数据库
DATABASE_URL=mysql+aiomysql://airesume:airesume_password@db:3306/ai_resume

# Docker Compose 内部连接使用 'db'
# 本地开发连接使用 'localhost'
# DATABASE_URL=mysql+aiomysql://airesume:airesume_password@localhost:3306/ai_resume

# 数据库连接池配置
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# ========== Redis 配置 ==========
REDIS_URL=redis://redis:6379/0

# ========== JWT 配置 ==========
# 生产环境必须使用至少 32 位的强密钥
SECRET_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_KEY_AT_LEAST_32_CHARACTERS_LONG

# ========== AI 模型配置 ==========
DEFAULT_AI_PROVIDER=xiaomi
XIAOMI_API_KEY=sk-your-xiaomi-api-key
OPENAI_API_KEY=sk-your-openai-api-key
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# ========== 应用配置 ==========
DEBUG=false
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000,http://localhost,https://yourdomain.com

# ========== 邮件配置（可选）==========
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# ========== 微信登录（可选）==========
# WECHAT_APP_ID=your-wechat-app-id
# WECHAT_APP_SECRET=your-wechat-app-secret
